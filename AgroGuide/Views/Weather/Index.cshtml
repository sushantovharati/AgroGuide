@{
    ViewData["Title"] = "Weather";
}

@section Styles {
    <link rel="stylesheet" href="~/css/weather.css" />
}

<!-- Hero Section -->
<section class="py-5 bg-success text-white">

    <div class="container text-center">

        <h1 class="fw-bold display-5">
            Weather Forecast & Farming Tips
        </h1>

        <p class="lead mt-3">
            Stay updated with weather conditions and smart farming guidance.
        </p>

    </div>

</section>

<!-- Current Weather -->
<section class="py-5 bg-light">

    <div class="container">

        <div class="row g-4">

            <!-- Weather Card -->
            <div class="col-lg-6">

                <div class="card border-0 shadow rounded-4 weather-card h-100">

                    <div class="card-body p-5">

                        <div class="d-flex justify-content-between align-items-center mb-4">

                            <div>

                                <h2 class="fw-bold text-success mb-1">
                                    Dhaka
                                </h2>

                                <p class="text-muted mb-0">
                                    Bangladesh
                                </p>

                            </div>

                            <div class="display-3">
                                ☁️
                            </div>

                        </div>

                        <h1 class="display-2 fw-bold mb-3">
                            31°C
                        </h1>

                        <h4 class="text-muted mb-4">
                            Cloudy Weather
                        </h4>

                        <div class="row text-center">

                            <div class="col-4">
                                <h5 class="fw-bold">78%</h5>
                                <p class="text-muted mb-0">Humidity</p>
                            </div>

                            <div class="col-4">
                                <h5 class="fw-bold">12 km/h</h5>
                                <p class="text-muted mb-0">Wind</p>
                            </div>

                            <div class="col-4">
                                <h5 class="fw-bold">20%</h5>
                                <p class="text-muted mb-0">Rain</p>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Farming Tips -->
            <div class="col-lg-6">

                <div class="card border-0 shadow rounded-4 weather-card h-100">

                    <div class="card-body p-5">

                        <h3 class="fw-bold text-success mb-4">
                            Farming Tips
                        </h3>

                        <div class="mb-4">

                            <h5 class="fw-semibold">
                                🌱 Irrigation Advice
                            </h5>

                            <p class="text-muted mb-0">
                                Moderate temperature today. Suitable for irrigation.
                            </p>

                        </div>

                        <div class="mb-4">

                            <h5 class="fw-semibold">
                                🌧 Rain Alert
                            </h5>

                            <p class="text-muted mb-0">
                                Low chance of rain. Fertilizer application is safe today.
                            </p>

                        </div>

                        <div>

                            <h5 class="fw-semibold">
                                ☀ Crop Suggestion
                            </h5>

                            <p class="text-muted mb-0">
                                Current weather is favorable for rice and vegetable crops.
                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- Weekly Forecast -->
<section class="pb-5 bg-light">

    <div class="container">

        <div class="card border-0 shadow rounded-4">

            <div class="card-body p-5">

                <h3 class="fw-bold text-success mb-4">
                    7-Day Forecast
                </h3>

                <div class="row text-center g-3">

                    <div class="col">
                        <div class="forecast-box p-3 rounded-4">
                            <h6>Mon</h6>
                            <div class="fs-2">☀️</div>
                            <h5>32°C</h5>
                        </div>
                    </div>

                    <div class="col">
                        <div class="forecast-box p-3 rounded-4">
                            <h6>Tue</h6>
                            <div class="fs-2">🌧</div>
                            <h5>29°C</h5>
                        </div>
                    </div>

                    <div class="col">
                        <div class="forecast-box p-3 rounded-4">
                            <h6>Wed</h6>
                            <div class="fs-2">☁️</div>
                            <h5>30°C</h5>
                        </div>
                    </div>

                    <div class="col">
                        <div class="forecast-box p-3 rounded-4">
                            <h6>Thu</h6>
                            <div class="fs-2">☀️</div>
                            <h5>33°C</h5>
                        </div>
                    </div>

                    <div class="col">
                        <div class="forecast-box p-3 rounded-4">
                            <h6>Fri</h6>
                            <div class="fs-2">🌧</div>
                            <h5>28°C</h5>
                        </div>
                    </div>

                    <div class="col">
                        <div class="forecast-box p-3 rounded-4">
                            <h6>Sat</h6>
                            <div class="fs-2">☁️</div>
                            <h5>31°C</h5>
                        </div>
                    </div>

                    <div class="col">
                        <div class="forecast-box p-3 rounded-4">
                            <h6>Sun</h6>
                            <div class="fs-2">☀️</div>
                            <h5>34°C</h5>
                        </div>
                    </div>

                </div>

            </div>

        </div>

    </div>

</section>