@model List<BLL.DTOs.DiseaseDTO>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Disease List";
}

<section class="py-5 bg-light">

    <div class="container">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h2 class="fw-bold text-success">
                    Disease Management
                </h2>

                <p class="text-muted mb-0">
                    Manage crop diseases and treatment information
                </p>
            </div>

            <a asp-controller="Disease"
                   asp-action="Create"
                   class="btn btn-success px-4 py-2 rounded-3">

                <i class="bi bi-plus-circle me-2"></i>
                Add Disease

            </a>

        </div>

        <!-- Table -->
        <div class="card border-0 shadow rounded-4">

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-success">

                            <tr>
                                <th>#</th>
                                <th>Disease Name</th>
                                <th>Symptoms</th>
                                <th>Causes</th>
                                <th>Solution</th>
                                <th>Prevention</th>
                                <th>Image URL</th>
                                @* <th>Status</th> *@
                                <th>Created At</th>
                                <th width="180">Actions</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>@item.Id</td>

                                    <td class="fw-semibold">
                                        @item.DiseaseName
                                    </td>

                                    <td>
                                        @item.Symptoms
                                    </td>

                                    <td>
                                        @item.Causes
                                    </td>

                                    <td>
                                        @item.Solution
                                    </td>

                                    <td>
                                        @item.Prevention
                                    </td>

                                    <td>
                                        @item.ImageUrl
                                    </td>

                                    @* <td>

                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                Inactive
                                            </span>
                                        }

                                    </td> *@

                                    <td>
                                        @(item.CreatedAt?.ToString("dd MMM yyyy"))
                                    </td>

                                    <td>

                                        <a asp-controller="Disease"
                                               asp-action="Update"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-warning">

                                            <i class="bi bi-pencil-square"></i>
                                            Edit

                                        </a>

                                        <a asp-controller="Disease"
                                               asp-action="Delete"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-danger">

                                            <i class="bi bi-trash"></i>
                                            Delete

                                        </a>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</section>