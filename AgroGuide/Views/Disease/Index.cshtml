@model List<BLL.DTOs.DiseaseDTO>

@{
    ViewData["Title"] = "Disease Guide";
}

@section Styles {
    <link rel="stylesheet" href="~/css/disease.css" />
}

<!-- Hero Section -->
<section class="py-5 bg-success text-white">

    <div class="container text-center">

        <h1 class="fw-bold display-5">
            Crop Disease Guide
        </h1>

        <p class="lead mt-3">
            Learn about common crop diseases, symptoms,
            prevention methods, and treatment solutions.
        </p>

    </div>

</section>

<!-- Disease Cards -->
<section class="py-5 bg-light">

    <div class="container">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>

                <h2 class="fw-bold text-success mb-1">
                    Common Crop Diseases
                </h2>

                <p class="text-muted mb-0">
                    Explore diseases affecting agricultural crops
                </p>

            </div>

        </div>

        <!-- Cards -->
        <div class="row g-4">

            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">

                    <div class="card h-100 border-0 shadow rounded-4 disease-card">

                        <!-- Image -->
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl"
                                 class="card-img-top rounded-top-4"
                                 style="height:240px; object-fit:cover;"
                                 alt="@item.DiseaseName" />
                        }
                        else
                        {
                            <div class="bg-success text-white d-flex align-items-center justify-content-center rounded-top-4"
                                 style="height:240px;">

                                <h3>@item.DiseaseName</h3>

                            </div>
                        }

                        <!-- Body -->
                        <div class="card-body p-4">

                            <h4 class="fw-bold text-success">
                                @item.DiseaseName
                            </h4>

                            <p class="mb-3 text-muted">
                                @item.Symptoms
                            </p>

                            <div class="mb-2">
                                <strong>Cause:</strong>
                                @item.Causes
                            </div>

                            <div class="mb-3">
                                <strong>Prevention:</strong>
                                @item.Prevention
                            </div>

                            <a asp-controller="Disease"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-success rounded-3">

                                View Details

                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

</section>