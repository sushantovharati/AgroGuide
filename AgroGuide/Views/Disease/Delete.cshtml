@model BLL.DTOs.DiseaseDTO

@{
    ViewData["Title"] = "Delete Disease";
}

<style>

    .delete-card {
        max-width: 500px;
        margin: 80px auto;
        padding: 35px;
        border-radius: 15px;
        background: #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        text-align: center;
    }

    .delete-icon {
        font-size: 60px;
        color: #dc3545;
        margin-bottom: 15px;
    }

    .delete-title {
        font-size: 32px;
        font-weight: 700;
        color: #dc3545;
        margin-bottom: 10px;
    }

    .disease-name {
        font-size: 24px;
        font-weight: 600;
        color: #333;
        margin-bottom: 30px;
    }

    .btn-group-custom {
        display: flex;
        justify-content: center;
        gap: 15px;
    }

    .btn-custom {
        min-width: 120px;
        padding: 10px 20px;
        font-size: 18px;
        border-radius: 8px;
    }

</style>

<div class="delete-card">

    <div class="delete-icon">
        <i class="bi bi-trash-fill"></i>
    </div>

    <h1 class="delete-title">
        Are You Sure?
    </h1>

    <p class="disease-name">
        @Model.DiseaseName
    </p>

    <form method="post">

        <input type="hidden"
               name="id"
               value="@Model.Id" />

        <div class="btn-group-custom">

            <input type="submit"
                   name="Decison"
                   value="Yes"
                   class="btn btn-danger btn-custom" />

            <input type="submit"
                   name="Decison"
                   value="No"
                   class="btn btn-primary btn-custom" />

        </div>

    </form>

</div>