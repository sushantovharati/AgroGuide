@model List<BLL.DTOs.FertilizerDTO>

@{
    ViewData["Title"] = "Fertilizer List";
}

<section class="py-5 bg-light">

    <div class="container">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h2 class="fw-bold text-success">
                    Fertilizer Management
                </h2>

                <p class="text-muted mb-0">
                    Manage all agricultural fertilizers
                </p>
            </div>

            <a asp-controller="Fertilizer"
                   asp-action="Create"
                   class="btn btn-success px-4 py-2 rounded-3">

                <i class="bi bi-plus-circle me-2"></i>
                Add Fertilizer

            </a>

        </div>

        <!-- Table -->
        <div class="card border-0 shadow rounded-4">

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-success">

                            <tr>
                                <th>#</th>
                                <th>Fertilizer Name</th>
                                <th>Type</th>
                                <th>Usage Instruction</th>
                                <th>Quantity/Acre</th>
                                <th>Price</th>
                                <th>Status</th>
                                <th width="180">Actions</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>@item.Id</td>
                                    <td class="fw-semibold">@item.FertilizerName</td>
                                    <td>@item.Type</td>
                                    <td>@item.UsageInstruction</td>
                                    <td>@item.QuantityPerAcre KG</td>
                                    <td>TK @item.Price</td>
                                    <td>

                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                Inactive
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        <a asp-controller="Fertilizer"
                                               asp-action="Update"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-warning">

                                            <i class="bi bi-pencil-square"></i>
                                            Edit

                                        </a>

                                        <a asp-controller="Fertilizer"
                                               asp-action="Delete"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-danger">

                                            <i class="bi bi-trash"></i>
                                            Delete

                                        </a>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</section>