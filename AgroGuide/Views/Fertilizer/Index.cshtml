@model List<BLL.DTOs.FertilizerDTO>

@{
    ViewData["Title"] = "Fertilizers";

    var role = Context.Session.GetString("Role");

    if (role == "Farmer")
    {
        Layout = "~/Views/Shared/_FarmerLayout.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/fertilizer.css" />
}

<!-- Hero Section -->
<section class="py-5 bg-success text-white">

    <div class="container text-center">

        <h1 class="fw-bold display-5">
            Fertilizer Guidance
        </h1>

        <p class="lead mt-3">
            Explore fertilizers, usage instructions,
            and crop nutrition support with AgroGuide.
        </p>

    </div>

</section>

<!-- Fertilizer Cards -->
<section class="py-5 bg-light">

    <div class="container">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>
                <h2 class="fw-bold text-success mb-1">
                    Available Fertilizers
                </h2>

                <p class="text-muted mb-0">
                    Browse fertilizers and farming nutrition support
                </p>
            </div>

        </div>

        <!-- Cards -->
        <div class="row g-4">

            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">

                    <div class="card h-100 border-0 shadow rounded-4 fertilizer-card">

                        <!-- Image -->
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl"
                                 class="card-img-top rounded-top-4"
                                 style="height:240px; object-fit:cover;"
                                 alt="@item.FertilizerName" />
                        }
                        else
                        {
                            <div class="bg-success text-white d-flex align-items-center justify-content-center rounded-top-4"
                                 style="height:240px;">

                                <h3>@item.FertilizerName</h3>

                            </div>
                        }

                        <!-- Body -->
                        <div class="card-body p-4">

                            <h4 class="fw-bold text-success">
                                @item.FertilizerName
                            </h4>

                            <p class="text-muted mb-2">
                                @item.Type Fertilizer
                            </p>

                            <p class="mb-3">
                                @item.UsageInstruction
                            </p>

                            <div class="mb-2">
                                <strong>Quantity Per Acre:</strong>
                                @item.QuantityPerAcre KG
                            </div>

                            <div class="mb-3">
                                <strong>Price:</strong>
                                TK @item.Price
                            </div>

                            <a asp-controller="Fertilizer"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-success rounded-3">

                                View Details

                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

</section>