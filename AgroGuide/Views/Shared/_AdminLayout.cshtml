<!-- File: Views/Shared/_AdminLayout.cshtml -->

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - AgroGuide Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AgroGuide.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- Navbar Start -->
    <header>
        <nav class="navbar navbar-expand-lg bg-white shadow-sm py-3 sticky-top">
            <div class="container">

                <a class="navbar-brand fw-bold fs-3 text-success"
                       asp-controller="Admin"
                       asp-action="Dashboard">

                    <i class="bi bi-shield-check me-2"></i>
                    Agro Guide Admin

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#adminNavbar"
                        aria-controls="adminNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse" id="adminNavbar">

                    <ul class="navbar-nav mx-auto gap-lg-3">

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                                   asp-controller="Admin"
                                   asp-action="Dashboard">

                                Dashboard

                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                                   asp-controller="Crop"
                                   asp-action="Index">

                                Manage Crops

                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                                   asp-controller="Fertilizer"
                                   asp-action="Index">

                                Manage Fertilizers

                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                                   asp-controller="Disease"
                                   asp-action="Index">

                                Manage Diseases

                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                                   asp-controller="Farmer"
                                   asp-action="Index">

                                Farmers

                            </a>
                        </li>

                    </ul>

                    <div class="d-flex align-items-center gap-3">

                        <span class="fw-semibold text-success">
                            <i class="bi bi-person-circle me-1"></i>
                            @Context.Session.GetString("UserName")
                        </span>

                        <a class="btn btn-success px-4 py-2 fw-semibold rounded-3"
                               asp-controller="Auth"
                               asp-action="Logout">

                            <i class="bi bi-box-arrow-right me-1"></i>
                            Logout

                        </a>

                    </div>

                </div>
            </div>
        </nav>
    </header>
    <!-- Navbar End -->
    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Footer Start -->
    <footer class="bg-dark text-light pt-5 pb-3">

        <div class="container">

            <div class="row">

                <div class="col-md-4 mb-4">

                    <h4 class="fw-bold text-success">
                        <i class="bi bi-shield-check me-2"></i>
                        Agro Guide Admin
                    </h4>

                    <p class="mt-3">
                        AgroGuide Admin Panel helps administrators manage crops,
                        fertilizers, diseases, and farmer information efficiently.
                    </p>

                </div>

                <div class="col-md-2 mb-4">

                    <h5 class="fw-bold">Management</h5>

                    <ul class="list-unstyled mt-3">

                        <li>
                            <a class="footer-link"
                                   asp-controller="Crop"
                                   asp-action="Index">

                                Crops

                            </a>
                        </li>

                        <li>
                            <a class="footer-link"
                                   asp-controller="Fertilizer"
                                   asp-action="Index">

                                Fertilizers

                            </a>
                        </li>

                        <li>
                            <a class="footer-link"
                                   asp-controller="Disease"
                                   asp-action="Index">

                                Diseases

                            </a>
                        </li>

                        <li>
                            <a class="footer-link"
                                   asp-controller="Farmer"
                                   asp-action="Index">

                                Farmers

                            </a>
                        </li>

                    </ul>

                </div>

                <div class="col-md-3 mb-4">

                    <h5 class="fw-bold">Admin Services</h5>

                    <ul class="list-unstyled mt-3">

                        <li>Crop Management</li>
                        <li>Fertilizer Management</li>
                        <li>Disease Management</li>
                        <li>Farmer Monitoring</li>

                    </ul>

                </div>

                <div class="col-md-3 mb-4">

                    <h5 class="fw-bold">Administrator</h5>

                    <p class="mt-3 mb-1">

                        <i class="bi bi-person-circle me-2"></i>

                        @Context.Session.GetString("UserName")

                    </p>

                    <p class="mb-1">

                        <i class="bi bi-envelope me-2"></i>

                        @Context.Session.GetString("UserEmail")

                    </p>

                    <p>

                        <i class="bi bi-shield-lock me-2"></i>

                        Secure Admin Access

                    </p>

                </div>

            </div>

            <hr class="border-secondary" />

            <div class="text-center">

                <p class="mb-0">
                    &copy; 2026 AgroGuide Admin Panel. All Rights Reserved.
                </p>

            </div>

        </div>

    </footer>
    <!-- Footer End -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>