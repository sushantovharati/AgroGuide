<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - AgroGuide</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AgroGuide.styles.css" asp-append-version="true" />
</head>

<body>

    <!-- Navbar Start -->
    <header>
        <nav class="navbar navbar-expand-lg bg-white shadow-sm py-3 sticky-top">
            <div class="container">

                <a class="navbar-brand fw-bold fs-3 text-success"
                       asp-controller="Home"
                       asp-action="Index">
                    <i class="bi bi-flower1 me-2"></i>Agro Guide
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <ul class="navbar-nav mx-auto gap-lg-3">

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Home"
                               asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Crop"
                               asp-action="Index">Crops</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Fertilizer"
                               asp-action="Index">Fertilizers</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Disease"
                               asp-action="Index">Disease Guide</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Weather"
                               asp-action="Index">Weather</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Home"
                               asp-action="About">About</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Home"
                               asp-action="Contact">Contact</a>
                        </li>

                    </ul>

                    <a class="btn btn-success px-4 py-2 fw-semibold rounded-3"
                           asp-controller="Auth"
                           asp-action="Login">
                        <i class="bi bi-person me-1"></i> Login/Register
                    </a>

                </div>
            </div>
        </nav>
    </header>
    <!-- Navbar End -->
    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Footer Start -->
    <footer class="bg-dark text-light pt-5 pb-3 mt-5">
        <div class="container">

            <div class="row">

                <div class="col-md-4 mb-4">
                    <h4 class="fw-bold text-success">
                        <i class="bi bi-flower1 me-2"></i>Agro Guide
                    </h4>
                    <p class="mt-3">
                        AgroGuide helps farmers get crop information, fertilizer guidance,
                        disease solutions, and weather-based farming support.
                    </p>
                </div>

                <div class="col-md-2 mb-4">
                    <h5 class="fw-bold">Quick Links</h5>
                    <ul class="list-unstyled mt-3">
                        <li><a class="footer-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a class="footer-link" asp-controller="Crop" asp-action="Index">Crops</a></li>
                        <li><a class="footer-link" asp-controller="Fertilizer" asp-action="Index">Fertilizers</a></li>
                        <li><a class="footer-link" asp-controller="Disease" asp-action="Index">Disease Guide</a></li>
                    </ul>
                </div>

                <div class="col-md-3 mb-4">
                    <h5 class="fw-bold">Services</h5>
                    <ul class="list-unstyled mt-3">
                        <li>Crop Recommendation</li>
                        <li>Fertilizer Suggestion</li>
                        <li>Disease Guide</li>
                        <li>Weather Alert</li>
                    </ul>
                </div>

                <div class="col-md-3 mb-4">
                    <h5 class="fw-bold">Contact</h5>
                    <p class="mt-3 mb-1">
                        <i class="bi bi-envelope me-2"></i>support.agroguide@gmail.com
                    </p>
                    <p class="mb-1">
                        <i class="bi bi-telephone me-2"></i>+880 1234-567890
                    </p>
                    <p>
                        <i class="bi bi-geo-alt me-2"></i>Dhaka, Bangladesh
                    </p>
                </div>

            </div>

            <hr class="border-secondary" />

            <div class="text-center">
                <p class="mb-0">
                    &copy; 2026 AgroGuide. All Rights Reserved.
                </p>
            </div>

        </div>
    </footer>
    <!-- Footer End -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>