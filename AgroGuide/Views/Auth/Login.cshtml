@model BLL.DTOs.LoginDTO

@{
    ViewData["Title"] = "Login";
}

<section class="login-section d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center align-items-center">

            <div class="col-lg-5 col-md-8">
                <div class="card border-0 shadow-lg rounded-4">
                    <div class="card-body p-5">

                        <div class="text-center mb-4">
                            <h2 class="fw-bold text-success">
                                Welcome Back
                            </h2>

                            <p class="text-muted">
                                Login to access your AgroGuide account
                            </p>
                        </div>

                        @if (TempData["LoginMsg"] != null)
                        {
                            <div class="alert alert-danger">
                                @TempData["LoginMsg"]
                            </div>
                        }

                        <form method="post">

                            <div class="mb-3">

                                <label class="form-label fw-semibold">
                                    Email Address
                                </label>

                                <input asp-for="Email"
                                       class="form-control form-control-lg"
                                       placeholder="Enter your email" />

                                <span asp-validation-for="Email" class="text-danger"></span>

                            </div>

                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Password
                                </label>

                                <input asp-for="Password"
                                       type="password"
                                       class="form-control form-control-lg"
                                       placeholder="Enter your password" />

                                <span asp-validation-for="Password" class="text-danger"></span>

                            </div>

                            <button type="submit"
                                    class="btn btn-success w-100 py-3 fw-semibold rounded-3">

                                <i class="bi bi-box-arrow-in-right me-2"></i>
                                Login

                            </button>

                        </form>

                        <div class="text-center mt-4">

                            <p class="text-muted mb-0">

                                New farmer?

                                <a asp-controller="Auth"
                                       asp-action="Register"
                                       class="text-success fw-semibold text-decoration-none">

                                    Register here

                                </a>

                            </p>

                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}