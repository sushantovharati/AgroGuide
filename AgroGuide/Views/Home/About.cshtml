@{
    ViewData["Title"] = "About";
}

<section class="py-5 bg-light">
    <div class="container">

        <div class="text-center mb-5">
            <h1 class="fw-bold text-success">About AgroGuide</h1>
            <p class="lead text-muted">
                Smart Agriculture Support & Farming Guidance Platform
            </p>
        </div>

        <div class="row align-items-center">

            <div class="col-lg-6 mb-4">
                <img src="https://images.unsplash.com/photo-1500937386664-56d1dfef3854?q=80&w=1200&auto=format&fit=crop"
                     class="img-fluid rounded-4 shadow"
                     alt="Agriculture">
            </div>

            <div class="col-lg-6">

                <h2 class="fw-bold mb-4">
                    Empowering Farmers with Smart Technology
                </h2>

                <p class="text-muted mb-3">
                    AgroGuide is a smart agriculture management platform designed
                    to help farmers make better farming decisions through technology.
                    The system provides crop information, fertilizer guidance,
                    disease management, and weather-based farming support.
                </p>

                <p class="text-muted mb-3">
                    Our goal is to improve agricultural productivity and support
                    farmers with reliable and easy-to-access farming knowledge.
                </p>

                <div class="row mt-4">

                    <div class="col-md-6 mb-3">
                        <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                            <div class="card-body">
                                <h5 class="fw-bold text-success">
                                    <i class="bi bi-tree me-2"></i>
                                    Crop Recommendation
                                </h5>

                                <p class="text-muted">
                                    Suggests suitable crops based on season,
                                    soil type, and farming conditions.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                            <div class="card-body">
                                <h5 class="fw-bold text-success">
                                    <i class="bi bi-bug me-2"></i>
                                    Disease Guide
                                </h5>

                                <p class="text-muted">
                                    Provides disease identification and
                                    treatment guidance for crops.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                            <div class="card-body">
                                <h5 class="fw-bold text-success">
                                    <i class="bi bi-droplet-half me-2"></i>
                                    Fertilizer Support
                                </h5>

                                <p class="text-muted">
                                    Helps farmers choose proper fertilizers
                                    and usage instructions.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                            <div class="card-body">
                                <h5 class="fw-bold text-success">
                                    <i class="bi bi-cloud-sun me-2"></i>
                                    Weather Alerts
                                </h5>

                                <p class="text-muted">
                                    Weather-based notifications and farming
                                    recommendations for better productivity.
                                </p>
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </div>

    </div>
</section>