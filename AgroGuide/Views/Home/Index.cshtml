@model List<BLL.DTOs.CropDTO>

@{
    ViewData["Title"] = "Home";
}
@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}
<!-- Trust Banner -->
<section class="py-5 bg-success text-white">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-lg-7">
                <h1 class="fw-bold display-5">
                    Smart Farming Starts with AgroGuide
                </h1>

                <p class="lead mt-3">
                    Get trusted crop information, fertilizer guidance,
                    disease support, and weather-based farming advice.
                </p>

                <a asp-controller="Auth"
                       asp-action="Login"
                       class="btn btn-light text-success fw-semibold px-4 py-2 mt-3">
                    Get Started
                </a>
            </div>

            <div class="col-lg-5 text-center mt-4 mt-lg-0">
                <h3 class="fw-bold">Trusted Agriculture Support</h3>
                <p class="mb-0">
                    Helping farmers make better decisions with reliable information.
                </p>
            </div>

        </div>
    </div>
</section>

<!-- Crop Section -->
<section class="py-5 bg-light">
    <div class="container">

        <div class="text-center mb-5">
            <h2 class="fw-bold text-success">Popular Crops</h2>
            <p class="text-muted">
                Explore crop details and farming guidance from AgroGuide
            </p>
        </div>

        <div class="row g-4">

            @foreach (var crop in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow rounded-4">

                        @if (!string.IsNullOrEmpty(crop.ImageUrl))
                        {
                            <img src="@crop.ImageUrl"
                                 class="card-img-top rounded-top-4"
                                 style="height:220px; object-fit:cover;"
                                 alt="@crop.CropName" />
                        }
                        else
                        {
                            <div class="bg-success text-white d-flex align-items-center justify-content-center rounded-top-4"
                                 style="height:220px;">
                                <h3>@crop.CropName</h3>
                            </div>
                        }

                        <div class="card-body p-4">
                            <h4 class="fw-bold text-success">
                                @crop.CropName
                            </h4>

                            <p class="text-muted fst-italic">
                                @crop.ScientificName
                            </p>

                            <p>
                                @crop.Description
                            </p>

                            <p class="mb-2">
                                <strong>Growth Duration:</strong>
                                @crop.GrowthDurationDays
                            </p>

                            <a asp-controller="Crop"
                                   asp-action="Details"
                                   asp-route-id="@crop.Id"
                                   class="btn btn-outline-success rounded-3">
                                View Details
                            </a>
                        </div>

                    </div>
                </div>
            }

        </div>
        <br />
        <a asp-controller="Crop"
               asp-action="Index"
               class="btn btn-outline-success rounded-3 px-4 view-all-btn">

            View All
            <i class="bi bi-arrow-right ms-1"></i>

        </a>


    </div>
</section>