@model List<BLL.DTOs.FarmerDTO>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Farmer List";
}

<section class="py-5 bg-light">

    <div class="container">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h2 class="fw-bold text-success">
                    Farmer Management
                </h2>

                <p class="text-muted mb-0">
                    Manage farmer information
                </p>

            </div>

        </div>

        <!-- Table -->
        <div class="card border-0 shadow rounded-4">

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-success">

                            <tr>

                                <th>#</th>
                                <th>Farmer Name</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th>Division</th>
                                <th>District</th>
                                <th>Address</th>
                                <th>Land Size</th>
                                <th>Created At</th>
                                <th width="120">Actions</th>

                            </tr>

                        </thead>

                        <tbody>
                            @{
                                var counter = 1;
                            }
                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        @counter
                                    </td>

                                    <td class="fw-semibold">
                                        @item.FirstName @item.LastName
                                    </td>

                                    <td>
                                        @item.Phone
                                    </td>

                                    <td>
                                        @item.Email
                                    </td>

                                    <td>
                                        @item.Division.DivisionName
                                    </td>

                                    <td>
                                        @item.District.DistrictName
                                    </td>

                                    <td>
                                        @item.Address
                                    </td>

                                    <td>
                                        @item.LandSize
                                    </td>

                                    <td>
                                        @(item.CreatedAt?.ToString("dd MMM yyyy"))
                                    </td>

                                    <td>

                                        <a asp-controller="Farmer"
                                               asp-action="Delete"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-danger">

                                            <i class="bi bi-trash"></i>
                                            Delete

                                        </a>

                                    </td>

                                </tr>
                                counter++;
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</section>
```
