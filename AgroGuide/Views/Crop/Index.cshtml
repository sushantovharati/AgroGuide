@model List<BLL.DTOs.CropDTO>


@{
    ViewData["Title"] = "Crops";

    var role = Context.Session.GetString("Role");

    if (role == "Farmer")
    {
        Layout = "~/Views/Shared/_FarmerLayout.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/crop.css" />
}

<!-- Hero Section -->
<section class="py-5 bg-success text-white">
    <div class="container text-center">

        <h1 class="fw-bold display-5">
            Explore Agricultural Crops
        </h1>

        <p class="lead mt-3">
            Discover crop details, growing seasons, soil requirements,
            and farming guidance with AgroGuide.
        </p>

    </div>
</section>

<!-- Crop List -->
<section class="py-5 bg-light">

    <div class="container">

        <!-- Section Header -->
        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>
                <h2 class="fw-bold text-success mb-1">
                    Available Crops
                </h2>

                <p class="text-muted mb-0">
                    Browse all crops available in AgroGuide
                </p>
            </div>

        </div>

        <!-- Cards -->
        <div class="row g-4">

            @foreach (var crop in Model)
            {
                <div class="col-lg-4 col-md-6">

                    <div class="card h-100 border-0 shadow crop-card rounded-4">

                        <!-- Image -->
                        @if (!string.IsNullOrEmpty(crop.ImageUrl))
                        {
                            <img src="@crop.ImageUrl"
                                 class="card-img-top rounded-top-4"
                                 style="height: 240px; object-fit: cover;"
                                 alt="@crop.CropName" />
                        }
                        else
                        {
                            <div class="bg-success text-white d-flex align-items-center justify-content-center rounded-top-4"
                                 style="height:240px;">

                                <h3>@crop.CropName</h3>

                            </div>
                        }

                        <!-- Body -->
                        <div class="card-body p-4">

                            <h4 class="fw-bold text-success">
                                @crop.CropName
                            </h4>

                            <p class="text-muted fst-italic mb-2">
                                @crop.ScientificName
                            </p>

                            <p class="mb-3">
                                @crop.Description
                            </p>

                            <div class="mb-2">
                                <strong>Category:</strong>
                                @crop.Category.Name
                            </div>

                            <div class="mb-2">
                                <strong>Season:</strong>
                                @crop.Season.SeasonName
                            </div>

                            <div class="mb-2">
                                <strong>Soil Type:</strong>
                                @crop.SoilType.SoilName
                            </div>

                            <div class="mb-3">
                                <strong>Growth Duration:</strong>
                                @crop.GrowthDurationDays
                            </div>

                            <a asp-controller="Crop"
                                   asp-action="Details"
                                   asp-route-id="@crop.Id"
                                   class="btn btn-outline-success rounded-3">

                                View Details

                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

</section>