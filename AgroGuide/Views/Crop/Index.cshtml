@model List<BLL.DTOs.CropDTO>

@{
    ViewData["Title"] = "Crop List";
}

<section class="py-5 bg-light">

    <div class="container">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h2 class="fw-bold text-success">
                    Crop Management
                </h2>

                <p class="text-muted mb-0">
                    Manage agricultural crops and farming information
                </p>
            </div>

            <a asp-controller="Crop"
                   asp-action="Create"
                   class="btn btn-success px-4 py-2 rounded-3">

                <i class="bi bi-plus-circle me-2"></i>
                Add Crop

            </a>

        </div>

        <!-- Table -->
        <div class="card border-0 shadow rounded-4">

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-success">

                            <tr>
                                <th>#</th>
                                <th>Crop Name</th>
                                <th>Scientific Name</th>
                                <th>Category Name</th>
                                <th>Season Name</th>
                                <th>Soil Type</th>
                                <th>Water Requirement</th>
                                <th>Growth Duration</th>
                                <th>Created At</th>
                                <th width="180">Actions</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>@item.Id</td>

                                    <td class="fw-semibold">
                                        @item.CropName
                                    </td>

                                    <td>
                                        <i>@item.ScientificName</i>
                                    </td>

                                    <td>
                                        @item.Category.Name
                                    </td>

                                    <td>
                                        @item.Season.SeasonName
                                    </td>

                                    <td>
                                        @item.SoilType.SoilName
                                    </td>

                                    <td>
                                        @item.WaterRequirement.LevelName
                                    </td>

                                    <td>
                                        @item.GrowthDurationDays
                                    </td>

                                    <td>
                                        @(item.CreatedAt?.ToString("dd MMM yyyy"))
                                    </td>

                                    <td>

                                        <a asp-controller="Crop"
                                               asp-action="Update"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-warning">

                                            <i class="bi bi-pencil-square"></i>
                                            Edit

                                        </a>

                                        <a asp-controller="Crop"
                                               asp-action="Delete"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-danger">

                                            <i class="bi bi-trash"></i>
                                            Delete

                                        </a>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</section>